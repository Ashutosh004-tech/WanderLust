<% layout('/layouts/boilerplate') -%>
<body>
    <h1 class="mb-4 mt-2">All Listing</h1>
    <!-- <form method="GET" action="/listings/new">
        <button>Add New Place</button>
    </form> -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(listing of allListing){ %> 
        <a href="/listings/<%=listing._id %>" class="listing-card">
            <div class="card col listing-card" >
                <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing Image" style="height: 20rem;">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                  <p class="card-text">
                    <b><%= listing.title %></b><br>
                    &#8377; <%=listing && listing.price!= null ? Number(listing.price).toLocaleString("en-IN"):"Price is Invalid"%>/night
                  </p>
                </div>
              </div>
        </a>
    <% } %>
</div>
</body>