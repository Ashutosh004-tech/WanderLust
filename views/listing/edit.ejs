<% layout('/layouts/boilerplate') -%>
<body>
  <h2>Edit Your Listing</h2>
  <br />
  <div class="row">
    <div class="col col-8 offset-2">
      <form
        method="POST"
        action="/listings/<%=listing._id %>?_method=PUT"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="titel" class="form-lable">Titel Name:</label>
          <input
            type="text"
            name="listing[title]"
            id="titel"
            value="<%=listing.title %>"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3">
          <label for="description" class="form-lable"
            >Write The Description:</label
          >
          <textarea
            name="listing[description]"
            required
            id="description"
            class="form-control"
          >
<%=listing.description %> ></textarea
          >
        </div>
        <div class="mb-3">
            <img src="<%= orginalImage %>" alt="">
            </div>
        <div class="mb-3">
          <label for="image" class="form-lable">Upload Image</label>
          <input
            type="file"
            name="listing[image]"
            id="image"
            value="<%=listing.image.filename %>"
            class="form-control"
          />
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-lable">Price for a night:</label>
            <input
              type="text"
              name="listing[price]"
              id="price"
              value="<%=listing.price %>"
              class="form-control"
              required
            />
          </div>
          <div class="mb-3 col-md-8">
            <label for="location" class="form-lable">Enter the location:</label>
            <input
              type="text"
              name="listing[location]"
              id="location"
              value="<%=listing.location %>"
              class="form-control"
              required
            />
          </div>
        </div>
        <div class="mb-3">
          <label for="country" class="form-lable"
            >Enter the Country name:</label
          >
          <input
            type="text"
            name="listing[country]"
            id="country"
            value="<%=listing.country %>"
            class="form-control"
            required
          />
        </div>
        <button class="btn btn-outline-success mt-2 mb-3">Done</button>
      </form>
    </div>
  </div>
</body>
